<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BeanScene1</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/BeanScene1._1.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar fixed-top navbar-expand-sm   border-bottom box-shadow">
            <div class="container-fluid  justify-content-center ">
                <div class="navbar-brand">
                    <a asp-area="" asp-controller="Home" asp-action="Index">
                        <img src="\images\logo.jpg" alt="logo" class="logo" />
                    </a>
                 </div>  
                <div class="mx-auto">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">Bean Scene</a>
               
                </div>
                <div>
                     <a class="nav-link text-dark" asp-area="" asp-controller="Reservations" asp-action="Index">Make a Reservation</a>
                </div>
    
                        
                        @if (User.IsInRole("Admin"))
                        {   
                            
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-area="" asp-controller="Areas" asp-action="Index">Areas</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-area="" asp-controller="Tables" asp-action="Index">Tables</a>
                            </li>
                            
                            
                            
                            <li class="nav-item">
                                 <a class="nav-link text-dark" asp-area="" asp-controller="Admin" asp-action="Index">Manage Staff</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-area="" asp-controller="Reports" asp-action="Index">Reports</a>
                            </li>
                           
                        }
                        @if (User.IsInRole("Staff"))
                        {
                             
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-area="" asp-controller="Areas" asp-action="Index">Areas</a>
                            </li>
                            
                            
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-area="" asp-controller="Tables" asp-action="Index">Tables</a>
                            </li>
                            
                        }

                        
                    
                    
                    <partial name="_LoginPartial" />
                </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container-fluid">
           <h6> &copy; 2025 - BeanScene - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a></h6>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="_framework/blazor.server.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
