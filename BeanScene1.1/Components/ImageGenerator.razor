@* Components/ImageGenerator.razor *@ 
<h3>Dynamic Image Generator</h3>

<div class="p-3 border rounded bg-light">
    <input @bind="text" class="form-control" placeholder="Enter text..." />
    <button class="btn btn-primary mt-2" @onclick="Generate">Generate</button>

@if (!string.IsNullOrEmpty(imageUrl))
{ 
    <div class="mt-3"> <img src="@imageUrl" class="border shadow-sm" /> 
        </div> 
} 
</div>

@code { 
    private string text = "Hello MVC + Blazor!"; 
    private string imageUrl;
    protected override void OnInitialized() => Generate();
    private void Generate() { // Add a timestamp to force refresh 
        imageUrl = $"api/image/generate?text={Uri.EscapeDataString(text)}&t={DateTime.Now.Ticks}"; } }